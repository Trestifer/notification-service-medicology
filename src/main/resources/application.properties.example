server.port=${PORT:8085}
spring.application.name=notification-service-medicology

notification.datasource.url=${NOTIFICATION_DATABASE_URL}
notification.datasource.username=${NOTIFICATION_DB_USERNAME}
notification.datasource.password=${NOTIFICATION_DB_PASSWORD}

spring.jpa.hibernate.ddl-auto=none
spring.jpa.open-in-view=false
spring.jpa.properties.hibernate.jdbc.time_zone=UTC

jwt.secret=${JWT_SECRET}
jwt.issuer=${JWT_ISSUER:medicology-auth}
jwt.audience=${JWT_AUDIENCE:medicology-api}

app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:3000,http://localhost:8085}
app.internal-service-token=${MEDICOLOGY_INTERNAL_SERVICE_TOKEN:}
auth.service-url=${AUTH_SERVICE_URL:http://localhost:8080}
learning.service-url=${LEARNING_SERVICE_URL:http://localhost:8081}

sendgrid.from-email=${SENDGRID_FROM_EMAIL:}
sendgrid.api.key=${SENDGRID_API_KEY:}

notification.reminder-zone=${NOTIFICATION_REMINDER_ZONE:Asia/Ho_Chi_Minh}
notification.streak-risk.cron=${NOTIFICATION_STREAK_RISK_CRON:0 30 21 * * *}
